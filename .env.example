# Use DEBUG=1 locally so /static/ is served from the `static/` folder (no collectstatic needed).
# Production: DEBUG=0 and run `python manage.py collectstatic`.
DEBUG=1
SECRET_KEY=change-me
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Postgres (recommended)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/whatsapp_ai
# (username: whatsapp_ai, password: postgres)

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# WhatsApp Cloud API webhook verification
WHATSAPP_VERIFY_TOKEN=aniket123
# Meta "App Secret" (NOT the WhatsApp Cloud API token).
# Get it: developers.facebook.com → Your App → App settings → Basic → App secret → Show.
# Used to verify webhook POST signatures (header X-Hub-Signature-256). Leave empty only for local testing.
META_APP_SECRET=27b420217c6b322be839ca89e976dd5b
